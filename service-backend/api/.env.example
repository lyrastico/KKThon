APP_NAME=kkthon-service-api
APP_DEBUG=true

# Supabase Postgres (pooler 6543 async souvent utilisé)
DATABASE_URL=postgresql+asyncpg://postgres.xxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
SYNC_DATABASE_URL=postgresql+psycopg://postgres.xxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# AWS S3 (zone raw : clés du type raw/<sha256>.<ext>)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=

CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
